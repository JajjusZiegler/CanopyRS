{
    "version": "2.0.0",
    "tasks": [

        // ── Initial setup ────────────────────────────────────────────────────
        {
            "label": "Setup: install CUDA 12.6 toolkit",
            "type": "shell",
            "command": "conda run -n canopyrs_env mamba install -y -c conda-forge cuda-nvcc=12.6.*",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },
        {
            "label": "Setup: create canopyrs_env",
            "type": "shell",
            "command": "conda create -y -n canopyrs_env -c conda-forge python=3.10 mamba",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },
        {
            "label": "Setup: init submodules",
            "type": "shell",
            "command": "cd ${CANOPYRS_REPO} && git submodule update --init --recursive",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },
        {
            "label": "Setup: install GDAL",
            "type": "shell",
            "command": "conda run -n canopyrs_env mamba install -y -c conda-forge gdal=3.6.2",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },
        {
            "label": "Setup: install core Python stack",
            "type": "shell",
            "command": "conda run -n canopyrs_env bash -lc \"set -e; pip install torch==2.7.1 torchvision==0.22.1 --index-url https://download.pytorch.org/whl/cu126 && python -m pip install -e ${CANOPYRS_REPO}\"",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },
        {
            "label": "Setup: install detectron2 and detrex",
            "type": "shell",
            "command": "conda run -n canopyrs_env bash -lc \"set -e; MAX_JOBS=4 python -m pip install --no-build-isolation -e ${CANOPYRS_REPO}/detrex/detectron2 -e ${CANOPYRS_REPO}/detrex\"",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },
        {
            "label": "Setup: rebuild detrex with CUDA 12.6",
            "type": "shell",
            "command": "conda run -n canopyrs_env python -m pip install ninja && conda run -n canopyrs_env bash -lc \"set -e; CUDA_HOME=/usr/local/cuda-12.6 PATH=/usr/local/cuda-12.6/bin:$PATH MAX_JOBS=4 python -m pip install --no-build-isolation -e ${CANOPYRS_REPO}/detrex/detectron2 && CUDA_HOME=/usr/local/cuda-12.6 PATH=/usr/local/cuda-12.6/bin:$PATH MAX_JOBS=4 python -m pip install --no-build-isolation -e ${CANOPYRS_REPO}/detrex\"",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },

