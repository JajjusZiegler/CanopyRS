            "command": "conda run -n canopyrs_env python ${CANOPYRS_REPO}/tools/temporal_crown_matcher.py --site PFY --discover '/mnt/m/working_package_2/2024_dronecampaign/tmp' -o '/mnt/m/working_package_2/2024_dronecampaign/tmp/temporal_ioa' --match-metric ioa --ioa-threshold 0.5 --centroid-distance 1.5 --max-date-gap 2 --min-dates 1 --geometry-method best_score",
