            "label": "Match: temporal crowns — Pfynwald (smoke test, output to /tmp)",
            "type": "shell",
            "command": "conda run -n canopyrs_env python ${CANOPYRS_REPO}/tools/temporal_crown_matcher.py --site PFY --dates 20240823 20240823 -i '/mnt/m/working_package_2/2024_dronecampaign/02_processing/metashape_projects/Upscale_Metashapeprojects/Pfynwald/20240823/CanopyRS/sam3_quality_mx_dual_ndvi/20240823_pfynwald_rgb_model_ortho_smooth_100_sf1p0_inferfinal.gpkg' '/mnt/m/working_package_2/2024_dronecampaign/02_processing/metashape_projects/Upscale_Metashapeprojects/Pfynwald/20240823/CanopyRS/sam3_quality_mx_dual_ndvi/20240823_pfynwald_rgb_model_ortho_smooth_100_sf1p0_inferfinal.gpkg' -o '/tmp/canopyrs_temporal_test/' --iou-threshold 0.3 --min-dates 1 --geometry-method best_score",
            "group": "test",
