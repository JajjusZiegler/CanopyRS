        // ── Temporal crown matching ───────────────────────────────────────────
        // Matches crown polygons across dates, assigns stable crown_id values,
        // and outputs reference_crowns_PFY.gpkg + per-date *_matched.gpkg files.
        //
        // IMPORTANT: Update the -i paths to point to the actual final .gpkg
        //   from each date's inference run once those runs are complete.
        //   The 20240823 path below is confirmed; 20250704 is a template.
        //
        // Flags:
        //   --iou-threshold  IoU cutoff to link two polygons as the same tree (0.3)
        //   --min-dates      Minimum dates seen to appear in reference output (1 = all)
        //   --geometry-method  best_score | union | largest
        {
            "label": "Match: temporal crowns — Pfynwald (all available dates)",
            "type": "shell",
            "command": "conda run -n canopyrs_env python ${CANOPYRS_REPO}/tools/temporal_crown_matcher.py --site PFY --dates 20240823 20250704 -i '/mnt/m/working_package_2/2024_dronecampaign/02_processing/metashape_projects/Upscale_Metashapeprojects/Pfynwald/20240823/CanopyRS/sam3_quality_mx_dual_ndvi/20240823_pfynwald_rgb_model_ortho_smooth_100_sf1p0_inferfinal.gpkg' '/mnt/m/working_package_2/2024_dronecampaign/02_processing/metashape_projects/Upscale_Metashapeprojects/Pfynwald/20250704/CanopyRS/sam3_quality_mx_dual_ndvi/20250704_pfynwald_rgb_model_ortho_smooth_100_sf1p0_inferfinal.gpkg' -o '/mnt/m/working_package_2/2024_dronecampaign/02_processing/metashape_projects/Upscale_Metashapeprojects/Pfynwald/temporal/' --iou-threshold 0.3 --min-dates 1 --geometry-method best_score",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": []
        },
